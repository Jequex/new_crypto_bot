{
  "name": "crypto-regime-bot",
  "version": "1.0.0",
  "private": true,
  "description": "Periodic crypto pair analysis bot that classifies market regime as bull, bear, or sideways.",
  "main": "dist/index.js",
  "scripts": {
    "ai:smoke": "npm run build && node scripts/ai-smoke.js",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "nodemon --watch src --ext ts --exec ts-node src/index.ts"
  },
  "dependencies": {
    "@tensorflow/tfjs": "^4.22.0",
    "@tensorflow/tfjs-node": "^4.22.0",
    "ccxt": "^4.4.78",
    "dotenv": "^16.4.7",
    "pg": "^8.20.0",
    "technicalindicators": "^3.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.11",
    "@types/pg": "^8.18.0",
    "nodemon": "^3.1.9",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.2"
  }
}
