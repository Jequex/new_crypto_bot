EXCHANGE_ID=bybit
RANKING_INTERVALS=15m,1h,4h,1d
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/trading_bot
RANKING_RUN_INTERVAL_MS=300000
LOOKBACK_LIMIT=250
RANKING_CONCURRENCY=4
QUOTE_CURRENCIES=USDT
MAX_PAIRS=25
OUTPUT_FORMAT=table
OUTPUT_LIMIT=25
EXCHANGE_TIMEOUT_MS=30000
EXCHANGE_RETRY_COUNT=2
ADX_TREND_THRESHOLD=20
EMA_SLOPE_THRESHOLD=0.0015
EMA_SPREAD_THRESHOLD=0.0025
SIDEWAYS_ATR_THRESHOLD=0.012
VOLUME_TREND_THRESHOLD=1.15
VOLUME_SIDEWAYS_THRESHOLD=0.9